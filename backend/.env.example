# ──────────────────────────────────────────────────────────────────────
# Trading System Backend — Environment Variables
# Copy this file to .env and fill in your actual values
# ──────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────
APP_NAME="Trading System API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development
TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ── Database (SQLite default, no setup needed) ───────────────────────
DATABASE_URL=sqlite+aiosqlite:///./trading.db
DB_ECHO=false

# ── CORS (set true for Render/cloud deploy) ───────────────────────────
CORS_ALLOW_ALL=false

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# ── Zerodha / Kite Connect ──────────────────────────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
KITE_REQUEST_TOKEN=

# ── Angel One / SmartAPI ─────────────────────────────────────────────
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# ── Alpaca (US Markets) ─────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Binance (Crypto) ────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# ── Data Providers ──────────────────────────────────────────────────
ALPHA_VANTAGE_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=
NEWS_API_KEY=

# ── Telegram Notifications ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Trading Parameters ──────────────────────────────────────────────
PAPER_TRADING=true
INITIAL_CAPITAL=1000000
MAX_CAPITAL_PER_TRADE_PCT=5.0
MAX_OPEN_POSITIONS=10
MAX_DAILY_LOSS_PCT=3.0
MAX_WEEKLY_LOSS_PCT=7.0
MAX_MONTHLY_LOSS_PCT=12.0
DEFAULT_STOP_LOSS_PCT=2.0
DEFAULT_TAKE_PROFIT_PCT=4.0
MIN_SIGNAL_SCORE=65.0
