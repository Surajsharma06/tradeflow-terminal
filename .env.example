# ================================================================
# AUTOMATED TRADING SYSTEM — ENVIRONMENT VARIABLES
# ================================================================
# Copy this file as .env and fill in your values
# NEVER commit .env to version control!
# ================================================================

# ── Database ──
DATABASE_URL=postgresql+asyncpg://trading:trading123@localhost:5432/trading_db
REDIS_URL=redis://localhost:6379/0

# ── Application ──
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=true

# ── Trading Config ──
PAPER_TRADING=true
INITIAL_CAPITAL_INR=1000000
INITIAL_CAPITAL_USD=10000
MAX_POSITIONS=10
BASE_RISK_PERCENT=1.0
HIGH_CONVICTION_RISK_PERCENT=2.0
SIGNAL_THRESHOLD=72
HIGH_CONVICTION_THRESHOLD=85
DAILY_LOSS_LIMIT_PERCENT=3.0
WEEKLY_LOSS_LIMIT_PERCENT=7.0
MONTHLY_LOSS_LIMIT_PERCENT=15.0
MAX_TRADES_PER_DAY=5

# ── Indian Brokers ──
# Zerodha Kite (Primary)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# Upstox (Secondary)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=

# Angel One (Tertiary)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_KEY=

# Fyers (F&O Specialist)
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_ACCESS_TOKEN=

# 5paisa (Backup)
FIVEPAISA_APP_NAME=
FIVEPAISA_APP_SOURCE=
FIVEPAISA_USER_ID=
FIVEPAISA_PASSWORD=
FIVEPAISA_USER_KEY=
FIVEPAISA_ENCRYPTION_KEY=

# ── International Brokers ──
# Alpaca (US Stocks — Commission Free)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Data Providers ──
ALPHA_VANTAGE_API_KEY=
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# ── Crypto Exchanges (via CCXT) ──
BINANCE_API_KEY=
BINANCE_SECRET=
COINBASE_API_KEY=
COINBASE_SECRET=
WAZIRX_API_KEY=
WAZIRX_SECRET=

# ── Notifications ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── News & Sentiment ──
NEWS_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TradingBot/1.0

# ── AI/ML ──
MODEL_DIR=./models
LSTM_MODEL_PATH=./models/lstm
XGBOOST_MODEL_PATH=./models/xgboost
PPO_MODEL_PATH=./models/ppo
SENTIMENT_MODEL=ProsusAI/finbert
